From 4db9212c11520a38ace71e2148f08c0825adcea9 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Miroslav=20Mr=C3=A1z?= <mraz.miro@seznam.cz>
Date: Mon, 18 May 2026 17:37:35 +0200
Subject: [PATCH v4] arm64: dts: qcom: sm7150-sunfish: add STMicro FTM5
 touchscreen
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Add the touchscreen node and supporting pinctrl for the bonded
display/touch assembly on the Google Pixel 4a (sunfish). The chip is
reachable on i2c7 at address 0x49, asserts an active-low interrupt on
tlmm GPIO 9, and exposes a reset line on tlmm GPIO 8 used by the
driver to bring the firmware up cleanly after power is applied.

VDD (1.8 V digital) and AVDD (3.0 V analog) are separate physical
supplies. Both share rails with the OLED panel because touch and
display are one bonded assembly: VDD comes from vreg_l13a_1p8 (also
the display vddio), AVDD from vreg_l7c_3p0 (also display vdda-3p3).
PM6150 GPIO 4 enables an external load switch upstream of these rails
and is asserted via pinctrl.

tlmm GPIO 72 multiplexes the touch IRQ between the AP (active-low) and
the SLPI sensor hub (active-high). Mainline only services the AP path,
so the line is held deasserted via mode-switch-gpios.

The compatible 'st,stmfts5' and the optional reset/mode-switch GPIO
bindings come from David Heidelberg's stmfts5 v4 series
(Message-Id: <20260409-stmfts5-v4-0-64fe62027db5@ixit.cz>).

Signed-off-by: Miroslav Mráz <mraz.miro@seznam.cz>
---
 .../boot/dts/qcom/sm7150-google-sunfish.dts   | 44 ++++++++++++++++++-
 1 file changed, 43 insertions(+), 1 deletion(-)

diff --git a/arch/arm64/boot/dts/qcom/sm7150-google-sunfish.dts b/arch/arm64/boot/dts/qcom/sm7150-google-sunfish.dts
index c32733862..61b5911c9 100644
--- a/arch/arm64/boot/dts/qcom/sm7150-google-sunfish.dts
+++ b/arch/arm64/boot/dts/qcom/sm7150-google-sunfish.dts
@@ -573,7 +573,23 @@ &i2c7 {
 	status = "okay";
 	clock-frequency = <1000000>;
 
-	/* st,fts touchscreen@49 */
+	touchscreen@49 {
+		compatible = "st,stmfts5";
+		reg = <0x49>;
+
+		interrupts-extended = <&tlmm 9 IRQ_TYPE_LEVEL_LOW>;
+		reset-gpios = <&tlmm 8 GPIO_ACTIVE_LOW>;
+		mode-switch-gpios = <&tlmm 72 GPIO_ACTIVE_LOW>;
+
+		vdd-supply = <&vreg_l13a_1p8>;
+		avdd-supply = <&vreg_l7c_3p0>;
+
+		touchscreen-size-x = <1080>;
+		touchscreen-size-y = <2340>;
+
+		pinctrl-names = "default";
+		pinctrl-0 = <&touch_irq_default &touch_reset_default &touch_power_default>;
+	};
 };
 
 &i2c9 {
@@ -663,6 +679,17 @@ &pm6150_charger {
 	status = "okay";
 };
 
+&pm6150_gpios {
+	touch_power_default: touch-power-default-state {
+		pins = "gpio4";
+		function = "normal";
+		qcom,drive-strength = <2>;
+		power-source = <1>;
+		bias-disable;
+		output-high;
+	};
+};
+
 &pm6150_qgauge {
 	monitored-battery = <&battery>;
 	power-supplies = <&pm6150_charger>;
@@ -870,6 +897,21 @@ rx-pins {
 			bias-pull-up;
 		};
 	};
+
+	touch_irq_default: touch-irq-default-state {
+		pins = "gpio9";
+		function = "gpio";
+		drive-strength = <2>;
+		bias-disable;
+	};
+
+	touch_reset_default: touch-reset-default-state {
+		pins = "gpio8";
+		function = "gpio";
+		drive-strength = <2>;
+		bias-pull-up;
+		output-high;
+	};
 };
 
 &uart3 {
